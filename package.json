{
  "name": "nerdbot",
  "version": "1.0.0",
  "description": "A polished Chrome MV3 side-panel AI assistant with multi-provider chat, skills, RAG, page context, voice, and image tools.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/savvops/nerdbot.git"
  },
  "bugs": {
    "url": "https://github.com/savvops/nerdbot/issues"
  },
  "homepage": "https://github.com/savvops/nerdbot#readme",
  "keywords": [
    "chrome-extension",
    "mv3",
    "side-panel",
    "ai-assistant",
    "llm",
    "rag",
    "gemini",
    "openai",
    "openrouter",
    "ollama",
    "anthropic"
  ],
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "package": "npm run build && cd dist && zip -r ../nerdbot-v$npm_package_version.zip . -x '*.map'"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@orama/plugin-data-persistence": "^3.1.18",
    "fuse.js": "^7.0.0",
    "highlight.js": "^11.10.0",
    "lucide-react": "^0.294.0",
    "pdfjs-dist": "^4.7.76",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.254",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
}
